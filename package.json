{
  "name": "cook",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test:runner": "node --require ts-node/register tests/index.test.ts",
    "test": "npm run test:all",
    "test:all": "npm run test:runner",
    "test:smoke": "node -e \"process.env.TEST_MODULE='smoke'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:auth": "node -e \"process.env.TEST_MODULE='auth'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:catalog": "node -e \"process.env.TEST_MODULE='catalog'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:companies": "node -e \"process.env.TEST_MODULE='companies'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:orders": "node -e \"process.env.TEST_MODULE='orders'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:reports": "node -e \"process.env.TEST_MODULE='reports'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "test:routes": "node -e \"process.env.TEST_MODULE='routes'; require('ts-node/register'); require(require('path').resolve('tests/index.test.ts'));\"",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make"
  },
  "keywords": [],
